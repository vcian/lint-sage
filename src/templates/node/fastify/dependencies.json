{
  "devDependencies": {
    "@commitlint/cli": "{{version:@commitlint/cli}}",
    "@commitlint/config-conventional": "{{version:@commitlint/config-conventional}}",
    "@typescript-eslint/eslint-plugin": "{{version:@typescript-eslint/eslint-plugin}}",
    "@typescript-eslint/parser": "{{version:@typescript-eslint/parser}}",
    "eslint": "{{version:eslint}}",
    "eslint-config-prettier": "{{version:eslint-config-prettier}}",
    "eslint-plugin-import": "{{version:eslint-plugin-import}}",
    "eslint-plugin-n": "{{version:eslint-plugin-n}}",
    "eslint-plugin-security": "{{version:eslint-plugin-security}}",
    "husky": "{{version:husky}}",
    "lint-staged": "{{version:lint-staged}}",
    "prettier": "{{version:prettier}}"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  }
}
