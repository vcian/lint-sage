{
  "devDependencies": {
    "@commitlint/cli": "{{version:@commitlint/cli}}",
    "@commitlint/config-conventional": "{{version:@commitlint/config-conventional}}",
    "@typescript-eslint/eslint-plugin": "{{version:@typescript-eslint/eslint-plugin}}",
    "@typescript-eslint/parser": "{{version:@typescript-eslint/parser}}",
    "@vcian/commitlint-config": "{{version:@vcian/commitlint-config}}",
    "@vcian/eslint-config-react": "{{version:@vcian/eslint-config-react}}",
    "@vcian/prettier-config": "{{version:@vcian/prettier-config}}",
    "eslint": "{{version:eslint}}",
    "eslint-config-prettier": "{{version:eslint-config-prettier}}",
    "eslint-plugin-import": "{{version:eslint-plugin-import}}",
    "eslint-plugin-jsx-a11y": "{{version:eslint-plugin-jsx-a11y}}",
    "eslint-plugin-react-hooks": "{{version:eslint-plugin-react-hooks}}",
    "eslint-plugin-unused-imports": "{{version:eslint-plugin-unused-imports}}",
    "husky": "{{version:husky}}",
    "lint-staged": "{{version:lint-staged}}",
    "prettier": "{{version:prettier}}"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  }
}
